----------------------------------------
Response:
{"sql":"SELECT \n  COUNT(CASE WHEN s.eye_colour_id = (SELECT id FROM colour WHERE colour = 'Blue') THEN 1 END) - \n  COUNT(CASE WHEN s.eye_colour_id IS NULL THEN 1 END) AS difference\nFROM superhero s\nWHERE s.weight_kg IS NULL;","rows":[[1]],"iterations":1,"ok":true,"error":null,"history":[{"node":"generate_sql","sql":"SELECT \n  COUNT(CASE WHEN s.eye_colour_id = (SELECT id FROM colour WHERE colour = 'Blue') THEN 1 END) - \n  COUNT(CASE WHEN s.eye_colour_id IS NULL THEN 1 END) AS difference\nFROM superhero s\nWHERE s.weight_kg IS NULL;"}]}

